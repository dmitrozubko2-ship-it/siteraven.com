@page "/admin"
@using Raven_Family.Services
@inject AuthService authService
@inject NavigationManager navigationManager

<PageTitle>Адмін панель - Сім'я Воронів</PageTitle>

@if (!authService.IsLoggedIn())
{
    <div class="alert alert-warning">
        <p>Будь ласка, <a href="/login">увійдіть</a> в свій акаунт.</p>
    </div>
}
else if (!authService.IsAdmin())
{
    <div class="alert alert-danger">
        <p>У вас немає доступу до адмін панелі!</p>
    </div>
}
else
{
    <div class="admin-container">
        <h1 class="admin-title">⚙️ Адмін панель</h1>

        <div class="welcome-box">
            <div>
                @{
                    var currentUser = authService.GetCurrentUser();
                    if (currentUser != null)
                    {
                        <p>Ласкаво просимо, <strong>@currentUser.Username</strong>!</p>
                        <small>Роль: <span class="role-badge">@authService.GetRoleDisplayName(authService.GetCurrentUserRole())</span></small>
                        @if (authService.IsTechAdmin())
                        {
                            <small style="color: #FFD700; margin-left: 1rem;">👑 ПОВНІ ПРАВА</small>
                        }
                    }
                }
            </div>
            <button class="btn btn-danger btn-sm" @onclick="HandleLogout">Вийти</button>
        </div>

        <div class="admin-tabs">
            <button class="tab-button @(activeTab == "dashboard" ? "active" : "")" @onclick="SetTabDashboard">
                📊 Панель керування
            </button>
            <button class="tab-button @(activeTab == "users" ? "active" : "")" @onclick="SetTabUsers">
                👥 Користувачі
            </button>
            @if (authService.CanManageRoles())
            {
                <button class="tab-button @(activeTab == "roles" ? "active" : "")" @onclick="SetTabRoles">
                    🎖️ Управління ролями
                </button>
            }
            <button class="tab-button @(activeTab == "news" ? "active" : "")" @onclick="SetTabNews">
                📰 Новини
            </button>
            <button class="tab-button @(activeTab == "members" ? "active" : "")" @onclick="SetTabMembers">
                👥 Члени сім'ї
            </button>
            <button class="tab-button @(activeTab == "rulesMgmt" ? "active" : "")" @onclick="SetTabRules">
                📜 Правила
            </button>
            @if (authService.IsTechAdmin())
            {
                <button class="tab-button @(activeTab == "activity" ? "active" : "")" @onclick="SetTabActivity">
                    📋 Активність
                </button>
                <button class="tab-button @(activeTab == "settings" ? "active" : "")" @onclick="SetTabSettings">
                    ⚙️ Налаштування
                </button>
                <button class="tab-button @(activeTab == "logs" ? "active" : "")" @onclick="SetTabLogs">
                    📝 Логи
                </button>
                <button class="tab-button @(activeTab == "security" ? "active" : "")" @onclick="SetTabSecurity">
                    🔒 Безпека
                </button>
            }
        </div>

        @if (activeTab == "dashboard")
        {
            <div class="tab-content">
                <h2>Статистика системи</h2>
                <div class="dashboard-grid">
                    <div class="stat-card">
                        <h3>Всього користувачів</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count</p>
                    </div>
                    <div class="stat-card">
                        <h3>Адміністраторів</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count(u => u.IsAdmin)</p>
                    </div>
                    <div class="stat-card">
                        <h3>Лідерів</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count(u => u.Role == UserRole.Лідер)</p>
                    </div>
                    <div class="stat-card">
                        <h3>Членів сім'ї</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count(u => u.Role == UserRole.УчасникСім_ї)</p>
                    </div>
                    <div class="stat-card">
                        <h3>Старший склад</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count(u => u.Role == UserRole.СтаршийСкладСім_ї)</p>
                    </div>
                    <div class="stat-card">
                        <h3>Заступників</h3>
                        <p class="stat-number">@authService.GetAllUsers().Count(u => u.Role == UserRole.Заступник)</p>
                    </div>
                </div>

                <div class="stats-section">
                    <div class="info-card">
                        <h3>📋 Системна інформація</h3>
                        <div class="info-grid">
                            <div class="info-item">
                                <strong>Версія системи:</strong>
                                <p>1.0.0</p>
                            </div>
                            <div class="info-item">
                                <strong>Остання активність:</strong>
                                <p>@DateTime.Now.ToString("dd.MM.yyyy HH:mm:ss")</p>
                            </div>
                            <div class="info-item">
                                <strong>Ваша роль:</strong>
                                <p>@authService.GetRoleDisplayName(authService.GetCurrentUserRole())</p>
                            </div>
                            <div class="info-item">
                                <strong>Статус:</strong>
                                <p><span class="badge bg-success">Активна</span></p>
                            </div>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3>👥 Розподіл ролей</h3>
                        <div class="role-distribution">
                            <div class="dist-item">
                                <span>Учасники</span>
                                <div class="progress" style="width: 100%;">
                                    <div class="progress-bar" style="width: @GetPercentage(authService.GetAllUsers().Count(u => u.Role == UserRole.УчасникСім_ї))%; background-color: #0f3460;">
                                        @authService.GetAllUsers().Count(u => u.Role == UserRole.УчасникСім_ї)
                                    </div>
                                </div>
                            </div>
                            <div class="dist-item">
                                <span>Старший склад</span>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @GetPercentage(authService.GetAllUsers().Count(u => u.Role == UserRole.СтаршийСкладСім_ї))%; background-color: #2c2c54;">
                                        @authService.GetAllUsers().Count(u => u.Role == UserRole.СтаршийСкладСім_ї)
                                    </div>
                                </div>
                            </div>
                            <div class="dist-item">
                                <span>Заступники</span>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @GetPercentage(authService.GetAllUsers().Count(u => u.Role == UserRole.Заступник))%; background-color: #c41e3a;">
                                        @authService.GetAllUsers().Count(u => u.Role == UserRole.Заступник)
                                    </div>
                                </div>
                            </div>
                            <div class="dist-item">
                                <span>Лідери</span>
                                <div class="progress">
                                    <div class="progress-bar" style="width: @GetPercentage(authService.GetAllUsers().Count(u => u.Role == UserRole.Лідер))%; background-color: #FFD700;">
                                        @authService.GetAllUsers().Count(u => u.Role == UserRole.Лідер)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "news")
        {
            <div class="tab-content">
                <div class="management-header">
                    <h3>📰 Керування новинами</h3>
                    <button class="btn btn-success btn-sm" @onclick="OpenAddNewsForm">
                        ➕ Нова новина
                    </button>
                </div>

                @if (editingNews != null)
                {
                    <div class="edit-form-container">
                        <div class="edit-form-card">
                            <h4>@(editingNews.Id == 0 ? "Додати нову новину" : "Редагувати новину")</h4>
                            <div class="form-group">
                                <label>Іконка/Емодзі:</label>
                                <input type="text" class="form-control" @bind="editingNews.Icon" placeholder="Напр.: 👥 або 🎮" maxlength="2" />
                            </div>
                            <div class="form-group">
                                <label>Заголовок:</label>
                                <input type="text" class="form-control" @bind="editingNews.Title" placeholder="Введіть заголовок новини" />
                            </div>
                            <div class="form-group">
                                <label>Вміст:</label>
                                <textarea class="form-control" @bind="editingNews.Content" rows="4" placeholder="Введіть вміст новини"></textarea>
                            </div>
                            <div class="form-group">
                                <label>Автор:</label>
                                <input type="text" class="form-control" @bind="editingNews.Author" placeholder="Ім'я автора" />
                            </div>
                            <div class="button-group">
                                <button class="btn btn-success" @onclick="SaveNews">💾 Зберегти</button>
                                <button class="btn btn-secondary" @onclick="CancelNewsEdit">❌ Скасувати</button>
                            </div>
                        </div>
                    </div>
                }

                <div class="news-management-list">
                    @foreach (var news in newsList)
                    {
                        <div class="news-management-card">
                            <div class="news-card-header">
                                <div>
                                    <span class="news-icon">@news.Icon</span>
                                    <strong>@news.Title</strong>
                                </div>
                                <span class="news-date">@news.Date.ToString("dd.MM.yyyy HH:mm")</span>
                            </div>
                            <div class="news-card-body">
                                <p>@news.Content</p>
                                <small style="color: rgba(232, 232, 232, 0.6);">Автор: @news.Author</small>
                            </div>
                            <div class="action-buttons">
                                <button class="btn btn-sm btn-info" @onclick="@(() => EditNews(news))">✏️ Редагувати</button>
                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteNews(news.Id))">🗑️ Видалити</button>
                            </div>
                        </div>
                    }
                </div>

                @if (newsList.Count == 0)
                {
                    <div class="empty-state">
                        <p>Новин поки немає. Додайте першу новину!</p>
                    </div>
                }
            </div>
        }
        else if (activeTab == "members")
        {
            <div class="tab-content">
                <div class="management-header">
                    <h3>👥 Керування членами сім'ї</h3>
                    <button class="btn btn-success btn-sm" @onclick="OpenAddMemberForm">
                        ➕ Новий член
                    </button>
                </div>

                @if (editingMember != null)
                {
                    <div class="edit-form-container">
                        <div class="edit-form-card">
                            <h4>@(editingMember.Id == 0 ? "Додати нового члена" : "Редагувати члена")</h4>
                            <div class="form-group">
                                <label>Нікнейм:</label>
                                <input type="text" class="form-control" @bind="editingMember.Nickname" placeholder="Введіть нікнейм" />
                            </div>
                            <div class="form-group">
                                <label>Ранг:</label>
                                <select class="form-control" @bind="editingMember.Rank">
                                    <option value="">-- Виберіть ранг --</option>
                                    <option value="Leader">👑 Лідер</option>
                                    <option value="Admin">🛡️ Адміністратор</option>
                                    <option value="Officer">⚔️ Офіцер</option>
                                    <option value="Member">🐦 Учасник</option>
                                    <option value="Recruit">🌱 Новобранець</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>URL аватара:</label>
                                <input type="url" class="form-control" @bind="editingMember.AvatarUrl" placeholder="https://..." />
                            </div>
                            <div class="form-group">
                                <label>Дата вступу:</label>
                                <input type="date" class="form-control" @bind="editingMember.JoinedDate" />
                            </div>
                            <div class="button-group">
                                <button class="btn btn-success" @onclick="SaveMember">💾 Зберегти</button>
                                <button class="btn btn-secondary" @onclick="CancelMemberEdit">❌ Скасувати</button>
                            </div>
                        </div>
                    </div>
                }

                <div class="members-management-grid">
                    @foreach (var member in membersList)
                    {
                        <div class="member-management-card">
                            <img src="@member.AvatarUrl" alt="@member.Nickname" class="member-avatar-small" />
                            <div class="member-info">
                                <strong>@member.Nickname</strong>
                                <div class="member-rank-badge">@GetRankIcon(member.Rank) @member.Rank</div>
                                <small>Вступив: @member.JoinedDate.ToString("dd.MM.yyyy")</small>
                            </div>
                            <div class="action-buttons">
                                <button class="btn btn-sm btn-info" @onclick="@(() => EditMember(member))">✏️</button>
                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteMember(member.Id))">🗑️</button>
                            </div>
                        </div>
                    }
                </div>

                @if (membersList.Count == 0)
                {
                    <div class="empty-state">
                        <p>Членів немає. Додайте першого члена!</p>
                    </div>
                }
            </div>
        }
        else if (activeTab == "rulesMgmt")
        {
            <div class="tab-content">
                <div class="management-header">
                    <h3>📜 Керування правилами</h3>
                    <button class="btn btn-success btn-sm" @onclick="OpenAddRuleForm">
                        ➕ Нове правило
                    </button>
                </div>

                @if (editingRule != null)
                {
                    <div class="edit-form-container">
                        <div class="edit-form-card">
                            <h4>@(editingRule.Id == 0 ? "Додати нове правило" : "Редагувати правило")</h4>
                            <div class="form-group">
                                <label>Категорія:</label>
                                <select class="form-control" @bind="editingRule.Category">
                                    <option value="">-- Виберіть категорію --</option>
                                    <option value="Загальні">⚡ Загальні правила</option>
                                    <option value="Заборонено">❌ Категорично заборонено</option>
                                    <option value="Покарання">⚖️ Система покарань</option>
                                    <option value="Вимоги">🎯 Вимоги для вступу</option>
                                    <option value="Ранги">🏆 Система рангів</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Заголовок:</label>
                                <input type="text" class="form-control" @bind="editingRule.Title" placeholder="Введіть заголовок" />
                            </div>
                            <div class="form-group">
                                <label>Вміст:</label>
                                <textarea class="form-control" @bind="editingRule.Content" rows="4" placeholder="Введіть вміст правила"></textarea>
                            </div>
                            <div class="button-group">
                                <button class="btn btn-success" @onclick="SaveRule">💾 Зберегти</button>
                                <button class="btn btn-secondary" @onclick="CancelRuleEdit">❌ Скасувати</button>
                            </div>
                        </div>
                    </div>
                }

                <div class="rules-management-container">
                    @{
                        var groupedRules = rulesList.GroupBy(r => r.Category);
                        @foreach (var group in groupedRules)
                        {
                            <div class="rules-section-management">
                                <div class="section-title">
                                    <strong>@group.Key</strong>
                                    <span class="rule-count">(@group.Count())</span>
                                </div>
                                <div class="rules-list-management">
                                    @foreach (var rule in group)
                                    {
                                        <div class="rule-item-management">
                                            <div>
                                                <strong>@rule.Title</strong>
                                                <p>@rule.Content</p>
                                            </div>
                                            <div class="action-buttons">
                                                <button class="btn btn-sm btn-info" @onclick="@(() => EditRule(rule))">✏️</button>
                                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteRule(rule.Id))">🗑️</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                @if (rulesList.Count == 0)
                {
                    <div class="empty-state">
                        <p>Правил немає. Додайте першого правила!</p>
                    </div>
                }
            </div>
        }
        else if (activeTab == "users")
        {
            <div class="tab-content">
                <div class="users-header">
                    <h3>Керування користувачами</h3>
                    <input type="text" class="form-control search-input" placeholder="🔍 Пошук по ім'ю або email..." @bind="searchQuery" />
                </div>
                <div class="table-responsive">
                    <table class="table table-dark">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Ім'я користувача</th>
                                <th>Email</th>
                                <th>Роль</th>
                                <th>Статус</th>
                                <th>Дата реєстрації</th>
                                <th>Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredUsers())
                            {
                                <tr>
                                    <td>@user.Id</td>
                                    <td><strong>@user.Username</strong></td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="role-badge">@authService.GetRoleDisplayName(user.Role)</span>
                                    </td>
                                    <td>
                                        <span class="badge @(user.IsAdmin ? "bg-danger" : "bg-secondary")">
                                            @(user.IsAdmin ? "Адмін" : "Користувач")
                                        </span>
                                    </td>
                                    <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        @if (user.Id != authService.GetCurrentUser().Id)
                                        {
                                            <div class="action-buttons">
                                                <button class="btn btn-sm btn-info" @onclick="@(() => EditUser(user))">
                                                    ✏️
                                                </button>
                                                <button class="btn btn-sm btn-danger" @onclick="@(() => DeleteUserConfirm(user))">
                                                    🗑️
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <small style="color: #999;">Це ви</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (editingUser != null)
                {
                    <div class="edit-modal">
                        <div class="edit-card">
                            <h4>Редагувати користувача</h4>
                            <div class="edit-form">
                                <div class="form-group">
                                    <label>Ім'я користувача:</label>
                                    <input type="text" class="form-control" @bind="editingUser.Username" />
                                </div>
                                <div class="form-group">
                                    <label>Email:</label>
                                    <input type="email" class="form-control" @bind="editingUser.Email" />
                                </div>
                                <div class="form-group">
                                    <label>
                                        <input type="checkbox" @bind="editingUser.IsAdmin" />
                                        Адміністратор
                                    </label>
                                </div>
                                <div class="button-group">
                                    <button class="btn btn-success" @onclick="SaveUser">💾 Зберегти</button>
                                    <button class="btn btn-secondary" @onclick="CancelEdit">❌ Відмінити</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (activeTab == "roles" && authService.CanManageRoles())
        {
            <div class="tab-content">
                <h3>🎖️ Управління ролями користувачів</h3>
                <div class="roles-container">
                    @foreach (var user in authService.GetAllUsers())
                    {
                        <div class="role-card">
                            <div class="role-card-header">
                                <h4>@user.Username</h4>
                                <small>@user.Email</small>
                            </div>
                            <div class="role-card-body">
                                <p><strong>Поточна роль:</strong> <span class="current-role">@authService.GetRoleDisplayName(user.Role)</span></p>
                                @if (user.Id != authService.GetCurrentUser().Id)
                                {
                                    <div style="margin-top: 1rem;">
                                        <label><strong>Змінити роль на:</strong></label>
                                        <div class="role-buttons">
                                            <button class="role-btn @(user.Role == UserRole.УчасникСім_ї ? "active" : "")" 
                                                    @onclick="@(() => ChangeRole(user.Id, UserRole.УчасникСім_ї))">
                                                👤 Участник сім'ї
                                            </button>
                                            @if (authService.CanPromoteToSenior())
                                            {
                                                <button class="role-btn @(user.Role == UserRole.СтаршийСкладСім_ї ? "active" : "")" 
                                                        @onclick="@(() => ChangeRole(user.Id, UserRole.СтаршийСкладСім_ї))">
                                                    🧑 Старший склад
                                                </button>
                                            }
                                            @if (authService.CanPromoteToDeputy())
                                            {
                                                <button class="role-btn @(user.Role == UserRole.Заступник ? "active" : "")" 
                                                        @onclick="@(() => ChangeRole(user.Id, UserRole.Заступник))">
                                                    🎩 Заступник
                                                </button>
                                            }
                                            @if (authService.CanPromoteToLeader())
                                            {
                                                <button class="role-btn @(user.Role == UserRole.Лідер ? "active" : "")" 
                                                        @onclick="@(() => ChangeRole(user.Id, UserRole.Лідер))">
                                                    👑 Лідер
                                                </button>
                                                <button class="role-btn @(user.Role == UserRole.ТехАдмін ? "active" : "")" 
                                                        @onclick="@(() => ChangeRole(user.Id, UserRole.ТехАдмін))">
                                                    🔧 Тех адмін
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <small style="color: #999; margin-top: 1rem; display: block;">Ви не можете змінити власну роль</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "activity" && authService.IsTechAdmin())
        {
            <div class="tab-content">
                <h3>📋 Активність системи</h3>
                <div class="activity-section">
                    <div class="activity-card">
                        <h4>🔐 Входи в акаунт</h4>
                        <div class="activity-list">
                            @foreach (var user in authService.GetAllUsers().OrderByDescending(u => u.CreatedAt).Take(10))
                            {
                                <div class="activity-item">
                                    <span class="time">@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                    <span class="action">Користувач <strong>@user.Username</strong> зареєстрований</span>
                                    <span class="badge bg-info">@authService.GetRoleDisplayName(user.Role)</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="activity-card">
                        <h4>👥 Останні дії</h4>
                        <div class="activity-list">
                            <div class="activity-item">
                                <span class="time">Зараз</span>
                                <span class="action">Ви переглядаєте адмін панель</span>
                                <span class="badge bg-success">Активно</span>
