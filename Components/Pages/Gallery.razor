                FullImageUrl = "https://via.placeholder.com/800?text=Політ"
            },
            new GalleryItem 
            { 
                Id = 2, 
                Title = "Матріарх", 
                Category = "Screenshots",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Матріарх",
                FullImageUrl = "https://via.placeholder.com/800?text=Матріарх"
            },
            new GalleryItem 
            { 
                Id = 3, 
                Title = "Витівки", 
                Category = "Memes",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Витівки",
                FullImageUrl = "https://via.placeholder.com/800?text=Витівки"
            },
            new GalleryItem 
            { 
                Id = 4, 
                Title = "Охоронець", 
                Category = "Events",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Охоронець",
                FullImageUrl = "https://via.placeholder.com/800?text=Охоронець"
            },
            new GalleryItem 
            { 
                Id = 5, 
                Title = "Молодий дослідник", 
                Category = "Screenshots",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Молодий",
                FullImageUrl = "https://via.placeholder.com/800?text=Молодий"
            },
            new GalleryItem 
            { 
                Id = 6, 
                Title = "Разом", 
                Category = "Events",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Разом",
                FullImageUrl = "https://via.placeholder.com/800?text=Разом"
            },
            new GalleryItem 
            { 
                Id = 7, 
                Title = "День сімейного святкування", 
                Category = "Events",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Святкування",
                FullImageUrl = "https://via.placeholder.com/800?text=Святкування"
            },
            new GalleryItem 
            { 
                Id = 8, 
                Title = "Смішна момента", 
                Category = "Memes",
                ThumbnailUrl = "https://via.placeholder.com/200?text=Смішна",
                FullImageUrl = "https://via.placeholder.com/800?text=Смішна"
            }
        };

        ShowAllGallery();
    }

    private void ShowAllGallery()
    {
        filteredGalleryItems = galleryItems.ToList();
    }

    private void ShowEventGallery()
    {
        filteredGalleryItems = galleryItems.Where(x => x.Category == "Events").ToList();
    }

    private void ShowScreenshotGallery()
    {
        filteredGalleryItems = galleryItems.Where(x => x.Category == "Screenshots").ToList();
    }

    private void ShowMemeGallery()
    {
        filteredGalleryItems = galleryItems.Where(x => x.Category == "Memes").ToList();
    }

    private void OpenLightbox(GalleryItem item)
    {
        selectedGalleryItem = item;
    }

    private void CloseLightbox()
    {
        selectedGalleryItem = null;
    }

    public class GalleryItem
    {
        public int Id { get; set; }
        public string Title { get; set; }
        public string Category { get; set; }
        public string ThumbnailUrl { get; set; }
        public string FullImageUrl { get; set; }
    }
}
