@page "/gallery"

<PageTitle>Галерея - Сім'я Воронів</PageTitle>

<div class="content">
    <h1 style="text-align: center; margin-top: 0;">🎨 Галерея сім'ї 🎨</h1>

    <p style="font-size: 1.1rem; margin-bottom: 2rem; text-align: center;">
        Відчуйте красу та величність нашої сім'ї воронів крізь чудові візуальні моменти.
    </p>

    <!-- Фільтри -->
    <div class="gallery-filters">
        <button class="filter-btn active" @onclick="ShowAllGallery">
            📸 Все
        </button>
        <button class="filter-btn" @onclick="ShowEventGallery">
            🎉 Івенти
        </button>
        <button class="filter-btn" @onclick="ShowScreenshotGallery">
            📷 Скріни
        </button>
        <button class="filter-btn" @onclick="ShowMemeGallery">
            😄 Меми
        </button>
    </div>

    <!-- Галерея з лайтбоксом -->
    <div class="gallery-grid">
        @foreach (var item in filteredGalleryItems)
        {
            <div class="gallery-item" @onclick="() => OpenLightbox(item)">
                <img src="@item.ThumbnailUrl" alt="@item.Title" />
            </div>
        }
    </div>

    <!-- Лайтбокс -->
    <div class="lightbox @(selectedGalleryItem != null ? "show" : "")" @onclick="CloseLightbox">
        @if (selectedGalleryItem != null)
        {
            <div class="lightbox-content" @onclick:stopPropagation="true">
                <span class="lightbox-close" @onclick="CloseLightbox">&times;</span>
                <img class="lightbox-img" src="@selectedGalleryItem.FullImageUrl" alt="@selectedGalleryItem.Title" />
                @if (!string.IsNullOrEmpty(selectedGalleryItem.Title))
                {
                    <p style="color: var(--light-color); text-align: center; margin-top: 1rem;">@selectedGalleryItem.Title</p>
                }
            </div>
        }
    </div>

    <div class="card" style="margin-top: 2rem;">
        <div class="card-body" style="padding: 2rem;">
            <h3 style="margin-top: 0;">📸 За об'єктивом</h3>
            <p>
                Наша галерея захоплює суть сімейного життя - тихі моменти роздумів, 
                веселі обміни та колективну силу, що визначає нашу сім'ю воронів. 
                Кожне зображення розповідає історію зв'язку, інтелекту та краси природи.
            </p>
        </div>
    </div>
</div>

