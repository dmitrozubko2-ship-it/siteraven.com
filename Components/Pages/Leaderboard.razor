        if (players.Count == 0)
        {
            players = new List<UserProfile>
            {
                new UserProfile
                {
                    Id = 1,
                    UserId = 1,
                    Level = 50,
                    ExperiencePoints = 50000,
                    Reputation = 5000,
                    CreatedAt = new DateTime(2021, 1, 15),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Ragnar&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Ragnar", Email = "ragnar@raven.com" }
                },
                new UserProfile
                {
                    Id = 2,
                    UserId = 2,
                    Level = 45,
                    ExperiencePoints = 45000,
                    Reputation = 4500,
                    CreatedAt = new DateTime(2021, 3, 20),
                    AvatarUrl = "https://ui-avatars.com/api/?name=ShadowRaven&background=c41e3a&color=fff",
                    User = new Models.User { Username = "ShadowRaven", Email = "shadow@raven.com" }
                },
                new UserProfile
                {
                    Id = 3,
                    UserId = 3,
                    Level = 42,
                    ExperiencePoints = 42000,
                    Reputation = 4200,
                    CreatedAt = new DateTime(2021, 6, 10),
                    AvatarUrl = "https://ui-avatars.com/api/?name=NightWing&background=c41e3a&color=fff",
                    User = new Models.User { Username = "NightWing", Email = "night@raven.com" }
                },
                new UserProfile
                {
                    Id = 4,
                    UserId = 4,
                    Level = 38,
                    ExperiencePoints = 38000,
                    Reputation = 3800,
                    CreatedAt = new DateTime(2021, 7, 5),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Whisper&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Whisper", Email = "whisper@raven.com" }
                },
                new UserProfile
                {
                    Id = 5,
                    UserId = 5,
                    Level = 35,
                    ExperiencePoints = 35000,
                    Reputation = 3500,
                    CreatedAt = new DateTime(2021, 9, 12),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Crow&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Crow", Email = "crow@raven.com" }
                },
                new UserProfile
                {
                    Id = 6,
                    UserId = 6,
                    Level = 32,
                    ExperiencePoints = 32000,
                    Reputation = 3200,
                    CreatedAt = new DateTime(2021, 10, 8),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Eclipse&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Eclipse", Email = "eclipse@raven.com" }
                },
                new UserProfile
                {
                    Id = 7,
                    UserId = 7,
                    Level = 28,
                    ExperiencePoints = 28000,
                    Reputation = 2800,
                    CreatedAt = new DateTime(2021, 11, 3),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Phoenix&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Phoenix", Email = "phoenix@raven.com" }
                },
                new UserProfile
                {
                    Id = 8,
                    UserId = 8,
                    Level = 25,
                    ExperiencePoints = 25000,
                    Reputation = 2500,
