@page "/leaderboard"
@using Raven_Family.Services
@using Raven_Family.Models
@inject UserProfileService userProfileService

<PageTitle>Топ гравців - Сім'я Воронів</PageTitle>

<div class="leaderboard-container">
    <h1>🏆 Топ найактивніших членів сім'ї</h1>
    <div class="tabs">
        <button class="tab-btn @(activeTab == "active" ? "active" : "")" @onclick='() => SetTab("active")'>
            🔥 Топ активних
        </button>
        <button class="tab-btn @(activeTab == "veterans" ? "active" : "")" @onclick='() => SetTab("veterans")'>
            👑 Ветерани
        </button>
        <button class="tab-btn @(activeTab == "reputation" ? "active" : "")" @onclick='() => SetTab("reputation")'>
            ⭐ За репутацією
        </button>
    </div>

    <div class="leaderboard-table">
        <div class="table-header">
            <div class="col-rank">#</div>
            <div class="col-player">Учасник</div>
            <div class="col-stat">@GetStatLabel()</div>
        </div>

        @foreach (var (player, index) in GetSortedPlayers().Select((p, i) => (p, i + 1)))
        {
            <div class="table-row @(index <= 3 ? "top-" + index : "")">
                <div class="col-rank">
                    <span class="rank-badge">@GetRankEmoji(index)@index</span>
                </div>
                <div class="col-player">
                    <div class="player-info">
                        <img src="@player.AvatarUrl" alt="Avatar" class="player-avatar">
                        <div>
                            <div class="player-name">@player.User?.Username</div>
                            <div class="player-level">Рівень @player.Level</div>
                        </div>
                    </div>
                </div>
                <div class="col-stat">
                    <span class="stat-highlight">@GetStatValue(player)</span>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string activeTab = "active";
    private List<UserProfile> players = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPlayersAsync();
    }

    private async Task LoadPlayersAsync()
    {
        players = await userProfileService.GetAllProfilesAsync();

