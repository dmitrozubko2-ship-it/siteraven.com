                    User = new Models.User { Username = "Raven", Email = "raven@raven.com" }
                },
                new UserProfile
                {
                    Id = 9,
                    UserId = 9,
                    Level = 22,
                    ExperiencePoints = 22000,
                    Reputation = 2200,
                    CreatedAt = new DateTime(2022, 5, 15),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Midnight&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Midnight", Email = "midnight@raven.com" }
                },
                new UserProfile
                {
                    Id = 10,
                    UserId = 10,
                    Level = 20,
                    ExperiencePoints = 20000,
                    Reputation = 2000,
                    CreatedAt = new DateTime(2021, 8, 22),
                    AvatarUrl = "https://ui-avatars.com/api/?name=Vortex&background=c41e3a&color=fff",
                    User = new Models.User { Username = "Vortex", Email = "vortex@raven.com" }
                }
            };
        }
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private IEnumerable<UserProfile> GetSortedPlayers()
    {
        return activeTab switch
        {
            "active" => players.OrderByDescending(p => p.ExperiencePoints).Take(50),
            "veterans" => players.OrderByDescending(p => p.CreatedAt).Take(50),
            "reputation" => players.OrderByDescending(p => p.Reputation).Take(50),
            _ => players.Take(50)
        };
    }

    private string GetStatLabel() => activeTab switch
    {
        "active" => "XP",
        "veterans" => "В грі з",
        "reputation" => "Репутація",
        _ => "Статистика"
    };

    private string GetStatValue(UserProfile player) => activeTab switch
    {
        "active" => player.ExperiencePoints.ToString("N0"),
        "veterans" => player.CreatedAt.ToString("dd.MM.yyyy"),
        "reputation" => player.Reputation.ToString(),
        _ => ""
    };

    private string GetRankEmoji(int position) => position switch
    {
        1 => "🥇 ",
        2 => "🥈 ",
        3 => "🥉 ",
        _ => ""
    };
}

<style>
.leaderboard-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
}

.leaderboard-container h1 {
    text-align: center;
    color: #d0a8ff;
    margin-bottom: 30px;
    font-size: 2.5em;
}

.tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    justify-content: center;
    flex-wrap: wrap;
}

.tab-btn {
    background: #1a0033;
    border: 2px solid #3d2d5e;
    color: #b899d6;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    font-weight: bold;
}

.tab-btn:hover,
.tab-btn.active {
    background: #9d4edd;
    color: white;
    border-color: #9d4edd;
}

.leaderboard-table {
    background: linear-gradient(135deg, #1a0033 0%, #2d1b69 100%);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #3d2d5e;
}

.table-header {
    display: grid;
    grid-template-columns: 60px 1fr 150px;
    background: #2d1b69;
    padding: 15px 20px;
    font-weight: bold;
    color: #d0a8ff;
    border-bottom: 2px solid #3d2d5e;
}

.table-row {
    display: grid;
    grid-template-columns: 60px 1fr 150px;
    padding: 15px 20px;
    border-bottom: 1px solid #3d2d5e;
    align-items: center;
    transition: background 0.2s;
}

.table-row:hover {
    background: rgba(157, 78, 221, 0.1);
}

.table-row.top-1 {
    background: rgba(255, 214, 10, 0.05);
    border-left: 4px solid #ffd60a;
}

.table-row.top-2 {
    background: rgba(192, 192, 192, 0.05);
    border-left: 4px solid #c0c0c0;
}

.table-row.top-3 {
    background: rgba(205, 127, 50, 0.05);
    border-left: 4px solid #cd7f32;
}

.col-rank {
    text-align: center;
}

.rank-badge {
    background: #9d4edd;
    color: white;
    padding: 5px 10px;
    border-radius: 20px;
    font-weight: bold;
    display: inline-block;
}

.col-player {
    display: flex;
}

.player-info {
    display: flex;
    gap: 15px;
    align-items: center;
}

.player-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 2px solid #9d4edd;
    object-fit: cover;
}

.player-name {
    font-weight: bold;
    color: #d0a8ff;
}

.player-level {
    font-size: 0.9em;
    color: #b899d6;
}

.col-stat {
    text-align: right;
}

.stat-highlight {
    font-weight: bold;
    color: #ffd60a;
    font-size: 1.1em;
}

@@media (max-width: 768px) {
    .table-header,
    .table-row {
        grid-template-columns: 40px 1fr 80px;
    }

    .player-avatar {
        width: 40px;
        height: 40px;
    }

    .leaderboard-container h1 {
        font-size: 1.8em;
    }
}
</style>
