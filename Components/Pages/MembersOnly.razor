@page "/members-only"
@using Raven_Family.Services
@inject AuthService authService
@inject NavigationManager navigationManager

<PageTitle>Закритий розділ - Сім'я Воронів</PageTitle>

@if (!authService.IsLoggedIn())
{
    <div class="access-denied">
        <div class="denied-icon">🔒</div>
        <h1>Доступ заборонено</h1>
        <p>Цей розділ доступний тільки для авторизованих членів сім'ї</p>
        <a href="/login" class="btn-login">Увійти в акаунт</a>
    </div>
}
else
{
    <div class="members-container">
        <div class="page-header">
            <h1>🔐 Закритий розділ рад лідерів</h1>
            <p class="subtitle">Стратегія • Внутрішні документи • Конфіденційна інформація</p>
        </div>

        <div class="content-tabs">
            <button class="tab @(activeTab == "strategy" ? "active" : "")" @onclick='() => SetTab("strategy")'>
                🎯 Стратегія
            </button>
            <button class="tab @(activeTab == "rules" ? "active" : "")" @onclick='() => SetTab("rules")'>
                📜 Правила
            </button>
            <button class="tab @(activeTab == "reports" ? "active" : "")" @onclick='() => SetTab("reports")'>
                📊 Звіти
            </button>
            <button class="tab @(activeTab == "votes" ? "active" : "")" @onclick='() => SetTab("votes")'>
                🗳️ Голосування
            </button>
        </div>

        @if (activeTab == "strategy")
        {
            <div class="content-section">
                <article class="article">
                    <h2>📈 Розвиток сім'ї на 2024 рік</h2>
                    <p class="meta">Опубліковано 15.01.2024 • Від: 👑 Лідер</p>
                    
                    <section>
                        <h3>1. Цілі на рік</h3>
                        <ul>
                            <li>Розширити кількість членів до 200</li>
                            <li>Запустити 3 великих проекти</li>
                            <li>Підвищити середню активність на 40%</li>
                            <li>Запустити платформу для взаємодії</li>
                        </ul>
                    </section>

                    <section>
                        <h3>2. Стратегія набору</h3>
                        <p>Фокусуватися на якості над кількістю. Кожен новий член повинен пройти:</p>
                        <ul>
                            <li>Співбесіду с адміном</li>
                            <li>Період випробування (2 тижні)</li>
                            <li>Офіційне затвердження рада лідерів</li>
                        </ul>
                    </section>

                    <section>
                        <h3>3. Проекти</h3>
                        <ul>
                            <li><strong>Проект Α (Ескорт):</strong> Запуск у березні 2024</li>
                            <li><strong>Проект Β (Розвідка):</strong> Запуск у червні 2024</li>
                            <li><strong>Проект Γ (Внутрішня розвідка):</strong> Запуск у вересні 2024</li>
                        </ul>
                    </section>
                </article>

                <article class="article pinned">
                    <span class="pin-badge">📌 Закріплено</span>
                    <h2>⚡ Критичні оновлення</h2>
                    <p><strong>17.01.2024:</strong> Нові правила модерації набирають чинності</p>
                    <p><strong>20.01.2024:</strong> Плановий сервісний контроль платформи</p>
                </article>
            </div>
        }
        else if (activeTab == "rules")
        {
            <div class="content-section">
                <article class="article">
                    <h2>📜 Внутрішні правила</h2>
                    <p class="meta">Останнє оновлення: 01.01.2024</p>
                    
                    <section>
                        <h3>1. Поведінка членів</h3>
                        <ul>
                            <li>Завжди бути вежливим та поважним</li>
                            <li>Не pubblikувати особисті дані</li>
                            <li>Дотримуватися розкладу зустрічей</li>
                        </ul>
                    </section>

                    <section>
                        <h3>2. Умови конфіденційності</h3>
                        <p>Вся інформація в цьому розділі є конфіденційною. Це поділення з членами без дозволу заборонено.</p>
                    </section>

                    <section>
                        <h3>3. Покарання за порушення</h3>
                        <ul>
                            <li><strong>Перше порушення:</strong> Письмове попередження</li>
                            <li><strong>Друге порушення:</strong> Тимчасова блокування (7 днів)</li>
                            <li><strong>Третє порушення:</strong> Вилучення з сім'ї</li>
                        </ul>
                    </section>
                </article>
            </div>
        }
        else if (activeTab == "reports")
        {
            <div class="content-section">
                <article class="article">
                    <h2>📊 Звіт про активність (Січень 2024)</h2>
                    
                    <div class="stats-grid">
                        <div class="stat-box">
                            <div class="stat-number">156</div>
                            <div class="stat-label">Активних членів</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number">+23</div>
                            <div class="stat-label">Нових учасників</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number">847</div>
                            <div class="stat-label">Повідомлень</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number">92%</div>
                            <div class="stat-label">Задоволеність</div>
                        </div>
                    </div>

                    <section>
                        <h3>Ключові показники</h3>
                        <ul>
                            <li>Середня активність на члена: 5.4 дій/день</li>
                            <li>Найактивнішо-гарячі дні: Пт-Сб</li>
                            <li>Основна тематика: Обговорення проектів (45%)</li>
                        </ul>
                    </section>
                </article>
            </div>
        }
        else if (activeTab == "votes")
        {
            <div class="content-section">
                <article class="article">
                    <h2>🗳️ Активні голосування</h2>
                    
                    <div class="vote-card">
                        <h3>Чи повинні ми запустити Проект Α раніше?</h3>
                        <p class="vote-meta">Голосування закривається за 2 дні</p>
                        
                        <div class="vote-options">
                            <div class="option">
                                <div class="option-bar">
                                    <div class="option-fill" style="width: 65%"></div>
                                </div>
                                <label>Так 👍 (65%)</label>
                            </div>
                            <div class="option">
                                <div class="option-bar">
                                    <div class="option-fill" style="width: 25%"></div>
                                </div>
                                <label>Ні 👎 (25%)</label>
                            </div>
                            <div class="option">
                                <div class="option-bar">
                                    <div class="option-fill" style="width: 10%"></div>
                                </div>
                                <label>Утримуюсь ❓ (10%)</label>
                            </div>
                        </div>
                    </div>

                    <div class="vote-card completed">
                        <h3>✓ Затверджено: Нова форма на сайт</h3>
                        <p class="vote-meta">Голосування завершено 15.01.2024</p>
                        <p><strong>Результат: 89% На користь</strong></p>
                    </div>
                </article>
            </div>
        }
    </div>
}

@code {
    private string activeTab = "strategy";

    private void SetTab(string tab)
    {
        activeTab = tab;
    }
}

<style>
.members-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px;
}

.page-header {
    text-align: center;
    margin-bottom: 40px;
}

.page-header h1 {
    color: #d0a8ff;
    font-size: 2.5em;
    margin: 0 0 10px 0;
}

.subtitle {
    color: #b899d6;
    font-size: 1.1em;
}

.access-denied {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, #1a0033 0%, #2d1b69 100%);
    border-radius: 15px;
    border: 2px solid #3d2d5e;
    color: white;
}

.denied-icon {
    font-size: 5em;
    margin-bottom: 20px;
}

.access-denied h1 {
    color: #d0a8ff;
    margin: 0 0 10px 0;
}

.access-denied p {
    color: #b899d6;
    font-size: 1.1em;
    margin-bottom: 30px;
}

.btn-login {
    display: inline-block;
    background: #9d4edd;
    color: white;
    padding: 12px 30px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s;
}

.btn-login:hover {
    background: #bb86fc;
    transform: scale(1.05);
}

.content-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    border-bottom: 2px solid #3d2d5e;
}

.tab {
    background: transparent;
    border: none;
    color: #b899d6;
    padding: 15px 20px;
    cursor: pointer;
    font-weight: bold;
    border-bottom: 3px solid transparent;
    transition: all 0.3s;
}

.tab:hover {
    color: #d0a8ff;
}

.tab.active {
    color: #ffd60a;
    border-bottom-color: #ffd60a;
}

.content-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.article {
    background: linear-gradient(135deg, #1a0033 0%, #2d1b69 100%);
    border: 2px solid #3d2d5e;
    border-radius: 10px;
    padding: 30px;
    color: white;
}

.article.pinned {
    border-color: #ffd60a;
    background: linear-gradient(135deg, #2d2d1a 0%, #4a4a2d 100%);
    position: relative;
}

.pin-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background: #ffd60a;
    color: #000;
    padding: 5px 10px;
    border-radius: 5px;
    font-weight: bold;
    font-size: 0.85em;
}

.article h2 {
    color: #d0a8ff;
    margin: 0 0 10px 0;
}

.meta {
    color: #b899d6;
    font-size: 0.9em;
    margin-bottom: 20px;
}

.article section {
    margin-bottom: 25px;
}

.article h3 {
    color: #ffd60a;
    margin-top: 0;
}

.article ul {
    color: #b899d6;
    padding-left: 20px;
}

.article li {
    margin-bottom: 8px;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
    margin: 20px 0;
}

.stat-box {
    background: rgba(0, 0, 0, 0.2);
    padding: 20px;
    border-radius: 8px;
    text-align: center;
    border: 1px solid #3d2d5e;
}

.stat-number {
    font-size: 2em;
    font-weight: bold;
    color: #ffd60a;
}

.stat-label {
    color: #b899d6;
    font-size: 0.9em;
    margin-top: 5px;
}

.vote-card {
    background: rgba(0, 0, 0, 0.2);
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 15px;
    border-left: 4px solid #9d4edd;
}

.vote-card.completed {
    border-left-color: #4caf50;
}

.vote-card h3 {
    margin: 0 0 10px 0;
    color: #d0a8ff;
}

.vote-meta {
    color: #b899d6;
    font-size: 0.9em;
    margin: 0 0 15px 0;
}

.vote-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.option {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.option-bar {
    background: #1a0033;
    border-radius: 5px;
    height: 25px;
    overflow: hidden;
}

.option-fill {
    background: linear-gradient(90deg, #9d4edd 0%, #bb86fc 100%);
    height: 100%;
}

.option label {
    color: #b899d6;
    font-size: 0.9em;
}

@@media (max-width: 768px) {
    .article {
        padding: 20px;
    }

    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .page-header h1 {
        font-size: 1.8em;
    }
}
</style>
