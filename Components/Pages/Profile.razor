@page "/profile/{userId:int}"
@using Raven_Family.Services
@using Raven_Family.Models
@inject AuthService authService
@inject NavigationManager navigationManager

<PageTitle>Профіль - Сім'я Воронів</PageTitle>

@if (profile != null)
{
    <div class="profile-container">
        <!-- Кнопка редагування -->
        @if (canEdit)
        {
            <div style="text-align: right; margin-bottom: 20px;">
                <button class="btn btn-primary" @onclick="ToggleEditMode" style="width: auto;">
                    @(isEditMode ? "❌ Скасувати" : "✏️ Редагувати Профіль")
                </button>
            </div>
        }

        <!-- Режим редагування -->
        @if (isEditMode && canEdit)
        {
            <div style="background: rgba(50, 20, 70, 0.5); border: 2px solid #8b3a8b; border-radius: 12px; padding: 30px; margin-bottom: 30px;">
                <h2 style="color: #ffd700; margin-top: 0;">✏️ Редагування Профілю</h2>
                
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 10px; color: #ddd; font-weight: bold;">Нікнейм</label>
                    <input type="text" class="form-control" @bind="editUsername" placeholder="Введіть новий нікнейм" />
                    <small style="color: #999;">Мінімум 3 символи</small>
                </div>

                @if (!string.IsNullOrEmpty(editMessage))
                {
                    <div style="background: rgba(@(editMessageIsError ? "220, 53, 69" : "76, 175, 80"), 0.2); border: 1px solid @(editMessageIsError ? "#dc3545" : "#4caf50"); color: @(editMessageIsError ? "#ffa5a5" : "#90EE90"); padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                        @editMessage
                    </div>
                }

                <div style="display: flex; gap: 10px;">
                    <button class="btn btn-success" @onclick="SaveChanges" style="flex: 1;">
                        💾 Зберегти Зміни
                    </button>
                </div>
            </div>
        }

        <!-- Профіль дані -->
        <div class="profile-header">
            <div class="profile-avatar">
                <img src="@profile.AvatarUrl" alt="Avatar" class="avatar-img">
                <div class="online-status @(profile.IsOnline ? "online" : "offline")">
                    @(profile.IsOnline ? "🟢" : "⚫")
                </div>
            </div>
            <div class="profile-info">
                <div class="profile-top">
                    <h1>@profile.User?.Username</h1>
                    <span class="rank-badge">@profile.Rank</span>
                </div>
                <p class="bio">@profile.Bio</p>
                <p class="last-seen">Останній раз: @profile.LastSeenAt.ToString("dd.MM.yyyy HH:mm")</p>
                
                <div class="stats-row">
                    <div class="stat">
                        <span class="stat-label">Рівень</span>
                        <span class="stat-value">@profile.Level</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Репутація</span>
                        <span class="stat-value">@profile.Reputation</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Активність</span>
                        <span class="stat-value">@profile.ActivityPoints</span>
                    </div>
                    <div class="stat">
                        <span class="stat-label">Монети</span>
                        <span class="stat-value">@profile.CoinsBalance</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="progress-section">
            <h2>🎯 Прогрес до наступного рівня</h2>
            <div class="progress-bar">
                <div class="progress-fill" style="width: @(GetProgressPercent())%"></div>
            </div>
            <p>@GetProgressText()</p>
        </div>

        <div class="veteran-section">
            <h2>📅 У Сім'ї</h2>
            <div class="veteran-info">
                <p><strong>@profile.DaysInFamily</strong> днів</p>
                @if (profile.DaysInFamily >= 365)
                {
                    <span class="veteran-badge">🎖️ Ветеран</span>
                }
                else if (profile.DaysInFamily >= 180)
                {
                    <span class="veteran-badge">🌟 Сталий Учасник</span>
                }
                else if (profile.DaysInFamily >= 30)
                {
                    <span class="veteran-badge">✨ Активний</span>
                }
            </div>
        </div>

        <div class="streak-section">
            <h2>🔥 Серія входів</h2>
            <div class="streak-info">
                <div class="streak-current">
                    <h3>Поточна: @profile.LoginStreak</h3>
                    <p>днів поспіль</p>
                </div>
                <div class="streak-max">
                    <h3>Рекорд: @profile.MaxLoginStreak</h3>
                    <p>днів</p>
                </div>
            </div>
        </div>

        <div class="achievements-section">
            <h2>🏆 Досягнення (@profile.Achievements.Count)</h2>
            @if (profile.Achievements.Count > 0)
            {
                <div class="achievements-grid">
                    @foreach (var achievement in profile.Achievements)
                    {
                        <div class="achievement-card">
                            <span class="achievement-icon">🎖️</span>
                            <p>@achievement.Title</p>
                            <small>@achievement.UnlockedAt</small>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-items">Ще немає досягнень. Починай з чогось великого!</p>
            }
        </div>

        <div class="contracts-section">
            <h2>📜 Контракти</h2>
            <div class="contract-stats">
                <div class="contract-stat">
                    <h4>Завершено</h4>
                    <p>@profile.ContractsCompleted</p>
                </div>
                <div class="contract-stat">
                    <h4>Активні</h4>
                    <p>@profile.ContractsActive</p>
                </div>
                <div class="contract-stat">
                    <h4>Всього заробив</h4>
                    <p>@profile.TotalContractValue</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="loading">
        <p>⏳ Завантаження профілю...</p>
    </div>
}

<style>
    .profile-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px 20px;
        color: #fff;
    }

    .profile-header {
        display: flex;
        gap: 30px;
        margin-bottom: 40px;
        background: rgba(50, 20, 70, 0.5);
        border: 2px solid #8b3a8b;
        border-radius: 12px;
        padding: 30px;
        backdrop-filter: blur(10px);
        flex-wrap: wrap;
    }

    .profile-avatar {
        position: relative;
        flex-shrink: 0;
    }

    .avatar-img {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 4px solid #c41e3a;
        object-fit: cover;
        box-shadow: 0 0 20px rgba(196, 30, 58, 0.5);
    }

    .online-status {
        position: absolute;
        bottom: 0;
        right: 0;
        font-size: 2em;
        background: rgba(0, 0, 0, 0.7);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    .online-status.online {
        background: rgba(0, 255, 0, 0.2);
    }

    .online-status.offline {
        background: rgba(128, 128, 128, 0.2);
    }

    .profile-info {
        flex: 1;
        min-width: 250px;
    }

    .profile-top {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 10px;
    }

    .profile-top h1 {
        margin: 0;
        font-size: 2.2em;
    }

    .rank-badge {
        background: linear-gradient(135deg, #ffd700, #c41e3a);
        color: #000;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: bold;
        font-size: 0.95em;
    }

    .bio {
        color: #ddd;
        margin: 10px 0;
        font-style: italic;
    }

    .last-seen {
        font-size: 0.9em;
        color: #999;
        margin: 5px 0 15px 0;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
        gap: 15px;
        margin-top: 15px;
    }

    .stat {
        background: rgba(30, 10, 40, 0.6);
        padding: 12px;
        border-radius: 8px;
        text-align: center;
        border: 1px solid #8b3a8b;
    }

    .stat-label {
        display: block;
        color: #8b3a8b;
        font-size: 0.85em;
        margin-bottom: 5px;
    }

    .stat-value {
        display: block;
        font-size: 1.8em;
        font-weight: bold;
        color: #ffd700;
    }

    .progress-section {
        background: rgba(50, 20, 70, 0.5);
        border: 2px solid #8b3a8b;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
        backdrop-filter: blur(10px);
    }

    .progress-bar {
        width: 100%;
        height: 25px;
        background: rgba(30, 10, 40, 0.6);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #8b3a8b;
        margin-bottom: 10px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #8b3a8b, #c41e3a);
        transition: width 0.3s ease;
        border-radius: 11px;
    }

    .veteran-section, .streak-section, .contracts-section {
        background: rgba(50, 20, 70, 0.5);
        border: 2px solid #8b3a8b;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
        backdrop-filter: blur(10px);
    }

    .veteran-info {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .veteran-info p {
        font-size: 2em;
        font-weight: bold;
        color: #ffd700;
        margin: 0;
    }

    .veteran-badge {
        background: linear-gradient(135deg, #8b3a8b, #c41e3a);
        padding: 8px 15px;
        border-radius: 20px;
        font-weight: bold;
        font-size: 0.9em;
    }

    .streak-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
    }

    .streak-current, .streak-max {
        background: rgba(30, 10, 40, 0.6);
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #c41e3a;
    }

    .streak-current h3, .streak-max h3 {
        color: #ffd700;
        margin: 0 0 5px 0;
    }

    .streak-current p, .streak-max p {
        color: #ddd;
        margin: 0;
        font-size: 0.9em;
    }

    .achievements-section {
        background: rgba(50, 20, 70, 0.5);
        border: 2px solid #8b3a8b;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
        backdrop-filter: blur(10px);
    }

    .achievements-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 15px;
    }

    .achievement-card {
        background: rgba(30, 10, 40, 0.6);
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        border: 1px solid #8b3a8b;
        transition: all 0.3s ease;
    }

    .achievement-card:hover {
        border-color: #c41e3a;
        box-shadow: 0 5px 15px rgba(196, 30, 58, 0.2);
    }

    .achievement-icon {
        font-size: 2em;
        display: block;
        margin-bottom: 8px;
    }

    .achievement-card p {
        margin: 8px 0;
        font-size: 0.9em;
        color: #ffd700;
    }

    .achievement-card small {
        color: #999;
    }

    .contract-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
    }

    .contract-stat {
        background: rgba(30, 10, 40, 0.6);
        padding: 20px;
        border-radius: 8px;
        text-align: center;
        border: 1px solid #8b3a8b;
    }

    .contract-stat h4 {
        color: #8b3a8b;
        margin: 0 0 10px 0;
        font-size: 0.95em;
    }

    .contract-stat p {
        font-size: 2em;
        font-weight: bold;
        color: #ffd700;
        margin: 0;
    }

    .no-items {
        text-align: center;
        color: #999;
        padding: 20px;
    }

    .loading {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }

    h2 {
        color: #ffd700;
        margin-top: 0;
    }

    .btn-success {
        background: #4caf50;
        border: 2px solid #4caf50;
        color: white;
    }

    .btn-success:hover {
        background: #45a049;
        border-color: #45a049;
    }
</style>

@code {
    [Parameter]
    public int UserId { get; set; }

    private UserProfile? profile;
    private bool canEdit = false;
    private bool isEditMode = false;
    private string editUsername = string.Empty;
    private string editMessage = string.Empty;
    private bool editMessageIsError = false;

    protected override void OnInitialized()
    {
        // Генеруємо тестовий профіль
        profile = new UserProfile
        {
            Id = UserId,
            UserId = UserId,
            User = new Models.User { Username = $"TestUser{UserId}", Email = $"test{UserId}@gmail.com" },
            Bio = "Я люблю Воронів! 🐦",
            AvatarUrl = $"https://ui-avatars.com/api/?name=TestUser{UserId}&background=c41e3a&color=fff",
            Level = 5,
            Reputation = 150,
            ActivityPoints = 450,
            CoinsBalance = 350,
            DaysInFamily = 90,
            LoginStreak = 15,
            MaxLoginStreak = 30,
            IsOnline = true,
            LastSeenAt = DateTime.Now,
            Rank = "Учасник",
            ContractsCompleted = 12,
            ContractsActive = 2,
            TotalContractValue = 2400
        };

        // Перевіряємо чи користувач може редагувати
        if (authService.IsLoggedIn())
        {
            var currentUser = authService.GetCurrentUser();
            canEdit = authService.CanEditUser(UserId);
            editUsername = profile.User?.Username ?? string.Empty;
        }
    }

    private void ToggleEditMode()
    {
        if (!canEdit) return;
        
        isEditMode = !isEditMode;
        editMessage = string.Empty;
        
        if (isEditMode)
        {
            editUsername = profile?.User?.Username ?? string.Empty;
        }
    }

    private async Task SaveChanges()
    {
        editMessage = string.Empty;

        // Валідація нікнейму
        if (string.IsNullOrWhiteSpace(editUsername) || editUsername.Length < 3)
        {
            editMessage = "❌ Нікнейм повинен містити мінімум 3 символи";
            editMessageIsError = true;
            return;
        }

        try
        {
            // Оновлюємо дані в сервісі
            if (authService.UpdateUsername(UserId, editUsername))
            {
                if (profile?.User != null)
                {
                    profile.User.Username = editUsername;
                }
                editMessage = "✓ Профіль успішно оновлено!";
                editMessageIsError = false;
                isEditMode = false;
                StateHasChanged();
                
                // Навігуємо назад на профіль
                await Task.Delay(1500);
                navigationManager.NavigateTo($"/profile/{UserId}");
            }
            else
            {
                editMessage = "❌ Помилка при оновленні профілю. Можливо, цей нікнейм вже використовується";
                editMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            editMessage = $"❌ Помилка: {ex.Message}";
            editMessageIsError = true;
        }

        StateHasChanged();
    }

    private int GetProgressPercent()
    {
        if (profile == null) return 0;
        var nextLevelXP = profile.Level * 1000;
        var currentXP = (int)(profile.ExperiencePoints % 1000);
        return currentXP * 100 / 1000;
    }

    private string GetProgressText()
    {
        if (profile == null) return "0 / 1000 XP";
        var nextLevelXP = 1000;
        var currentProgress = (int)(profile.ExperiencePoints % 1000);
        return $"{currentProgress} / {nextLevelXP} XP";
    }
}
