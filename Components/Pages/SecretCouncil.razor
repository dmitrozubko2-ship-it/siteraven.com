@page "/secret-council"
@using Raven_Family.Services
@inject NavigationManager navigationManager
@inject AuthService authService
@rendermode InteractiveServer

<PageTitle>🤫 Таємна Рада - Сім'я Воронів</PageTitle>

@if (isAuthorized && currentUser != null && (currentUser.IsAdmin || currentUser.Role >= UserRole.ТехАдмін))
{
    <div class="secret-council">
        <div class="council-header">
            <h1>🤫 Таємна Рада Воронів</h1>
            <p class="subtitle">Доступ обмежено для вищого керівництва</p>
        </div>

        <div class="council-tabs">
            <button class="tab-btn @(activeTab == "strategy" ? "active" : "")" @onclick="SelectTabStrategy">
                📋 Стратегія
            </button>
            <button class="tab-btn @(activeTab == "rules" ? "active" : "")" @onclick="SelectTabRules">
                🔐 Внутрішні правила
            </button>
            <button class="tab-btn @(activeTab == "votes" ? "active" : "")" @onclick="SelectTabVotes">
                🗳️ Голосування
            </button>
        </div>

        @if (activeTab == "strategy")
        {
            <div class="council-content">
                <h2>Стратегічний План</h2>
                <div class="strategy-card">
                    <h3>📈 Розвиток сім'ї</h3>
                    <ul>
                        <li>Залучення 50+ активних учасників до кінця року</li>
                        <li>Впровадження системи рангів і репутації</li>
                        <li>Запуск внутрішньої валюти "Вороні монети"</li>
                        <li>Інтеграція з Discord для спільноти</li>
                    </ul>
                </div>

                <div class="strategy-card">
                    <h3>💎 Економіка</h3>
                    <ul>
                        <li>Базова ставка: 100 монет за новачка</li>
                        <li>За активність: +10 монет на день</li>
                        <li>Бонус за контракти: 20-100 монет</li>
                        <li>Штраф за неактивність: -5 монет на тиждень</li>
                    </ul>
                </div>

                <div class="strategy-card">
                    <h3>🎯 Цілі на квартал</h3>
                    <ul>
                        <li>Q1: Побудова фундаменту (Структура, Модели)</li>
                        <li>Q2: Активація (Система прогресу, Вибори)</li>
                        <li>Q3: Розширення (Інтеграції, Магазин)</li>
                        <li>Q4: Оптимізація (Мобіль, Аналітика)</li>
                    </ul>
                </div>
            </div>
        }

        @if (activeTab == "rules")
        {
            <div class="council-content">
                <h2>🔐 Внутрішні Правила</h2>
                <div class="rules-list">
                    <div class="rule-card">
                        <h3>1. Про голосування</h3>
                        <p>Голос кожного учасника має вагу залежно від його рангу:</p>
                        <ul>
                            <li>Новачок: 0.5 голоса</li>
                            <li>Учасник: 1 голос</li>
                            <li>Ветеран: 2 голоса</li>
                            <li>Герой: 3 голоса</li>
                            <li>Легенда: 5 голосів</li>
                        </ul>
                    </div>

                    <div class="rule-card">
                        <h3>2. Про монети</h3>
                        <p>Монети можна заробляти та витрачати на:</p>
                        <ul>
                            <li>Покупку ролей у магазині</li>
                            <li>Взяття спеціальних контрактів</li>
                            <li>Обміну на привілеї та нагороди</li>
                        </ul>
                    </div>

                    <div class="rule-card">
                        <h3>3. Про репутацію</h3>
                        <p>Репутація зростає за:</p>
                        <ul>
                            <li>Виконання контрактів (+10 за кожен)</li>
                            <li>Участь у голосуваннях (+2)</li>
                            <li>Хорошу поведінку та активність</li>
                        </ul>
                    </div>

                    <div class="rule-card">
                        <h3>4. Про санкції</h3>
                        <p>За порушення правил:</p>
                        <ul>
                            <li>Перше попередження: -20 репутації</li>
                            <li>Друге попередження: -50 репутації + заборона голосу</li>
                            <li>Третє: Вилучення з сім'ї</li>
                        </ul>
                    </div>
                </div>
            </div>
        }

        @if (activeTab == "votes")
        {
            <div class="council-content">
                <h2>🗳️ Активні Голосування</h2>
                
                <div class="votes-list">
                    <div class="vote-card">
                        <h3>Прийняти нового учасника - Vasyl?</h3>
                        <p class="vote-description">Vasyl просить прийняти його до нашої сім'ї. Потрібна 70% підтримка.</p>
                        <div class="vote-stats">
                            <div class="vote-bar for">
                                <div class="progress" style="width: 68%;">За: 15 голосів (68%)</div>
                            </div>
                            <div class="vote-bar against">
                                <div class="progress" style="width: 32%;">Проти: 7 голосів (32%)</div>
                            </div>
                        </div>
                        <div class="vote-timer">⏱️ Залишилось 2 дні 14 годин</div>
                        @if (currentUser != null)
                        {
                            <div class="vote-buttons">
                                <button class="vote-btn for-btn" @onclick="() => CastVote(1, true)">✅ За</button>
                                <button class="vote-btn against-btn" @onclick="() => CastVote(1, false)">❌ Проти</button>
                            </div>
                        }
                    </div>

                    <div class="vote-card">
                        <h3>Змінити колір офіційного фону?</h3>
                        <p class="vote-description">Пропозиція: змінити фіолетовий на чорно-сірий з воронячим мотивом.</p>
                        <div class="vote-stats">
                            <div class="vote-bar for">
                                <div class="progress" style="width: 45%;">За: 9 голосів (45%)</div>
                            </div>
                            <div class="vote-bar against">
                                <div class="progress" style="width: 55%;">Проти: 11 голосів (55%)</div>
                            </div>
                        </div>
                        <div class="vote-timer">⏱️ Залишилось 1 день 3 години</div>
                        @if (currentUser != null)
                        {
                            <div class="vote-buttons">
                                <button class="vote-btn for-btn" @onclick="() => CastVote(2, true)">✅ За</button>
                                <button class="vote-btn against-btn" @onclick="() => CastVote(2, false)">❌ Проти</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="no-access">
        <h1>🚫 Доступ Заборонено</h1>
        <p>Ця сторінка доступна тільки для авторизованих адміністраторів.</p>
        <a href="/login">Увійти</a>
    </div>
}

<style>
    .secret-council {
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .council-header {
        text-align: center;
        margin-bottom: 40px;
        color: #fff;
    }

    .council-header h1 {
        font-size: 3em;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #2c1a2c, #8b3a8b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .subtitle {
        color: #8b3a8b;
        font-style: italic;
    }

    .council-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }

    .tab-btn {
        padding: 12px 24px;
        background: rgba(50, 20, 70, 0.6);
        border: 2px solid #8b3a8b;
        color: #fff;
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.3s ease;
        font-size: 1em;
        backdrop-filter: blur(10px);
    }

    .tab-btn:hover {
        border-color: #c41e3a;
        color: #ffd700;
    }

    .tab-btn.active {
        background: linear-gradient(135deg, #8b3a8b, #c41e3a);
        border-color: #c41e3a;
        color: #fff;
    }

    .council-content {
        background: rgba(30, 10, 40, 0.8);
        border: 2px solid #8b3a8b;
        border-radius: 12px;
        padding: 30px;
        backdrop-filter: blur(10px);
        color: #fff;
    }

    .strategy-card, .rule-card {
        background: rgba(50, 20, 70, 0.5);
        border-left: 4px solid #c41e3a;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 8px;
    }

    .strategy-card h3, .rule-card h3 {
        color: #ffd700;
        margin-top: 0;
    }

    .vote-card {
        background: rgba(50, 20, 70, 0.6);
        border: 2px solid #8b3a8b;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .vote-card:hover {
        border-color: #c41e3a;
        box-shadow: 0 5px 20px rgba(196, 30, 58, 0.2);
    }

    .vote-card h3 {
        color: #ffd700;
        margin-top: 0;
    }

    .vote-description {
        color: #ddd;
        margin-bottom: 15px;
    }

    .vote-stats {
        margin-bottom: 15px;
    }

    .vote-bar {
        margin-bottom: 10px;
    }

    .vote-bar.for .progress {
        background: linear-gradient(90deg, #00ff00, #00aa00);
        color: #fff;
        padding: 5px 10px;
        border-radius: 4px;
        font-weight: bold;
    }

    .vote-bar.against .progress {
        background: linear-gradient(90deg, #ff0000, #aa0000);
        color: #fff;
        padding: 5px 10px;
        border-radius: 4px;
        font-weight: bold;
    }

    .vote-timer {
        color: #ff9999;
        font-size: 0.9em;
        margin-bottom: 15px;
    }

    .vote-buttons {
        display: flex;
        gap: 10px;
    }

    .vote-btn {
        flex: 1;
        padding: 10px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .for-btn {
        background: linear-gradient(135deg, #00ff00, #00aa00);
        color: #000;
    }

    .for-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 255, 0, 0.3);
    }

    .against-btn {
        background: linear-gradient(135deg, #ff6b6b, #c41e3a);
        color: #fff;
    }

    .against-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(196, 30, 58, 0.3);
    }

    .no-access {
        text-align: center;
        padding: 60px 20px;
        color: #fff;
    }

    .no-access h1 {
        color: #c41e3a;
        margin-bottom: 20px;
    }

    .no-access a {
        display: inline-block;
        padding: 12px 30px;
        background: linear-gradient(135deg, #8b3a8b, #c41e3a);
        color: #fff;
        text-decoration: none;
        border-radius: 8px;
        margin-top: 20px;
        transition: all 0.3s ease;
    }

    .no-access a:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(196, 30, 58, 0.3);
    }

    ul {
        margin: 10px 0;
        padding-left: 20px;
    }

    ul li {
        margin-bottom: 8px;
        color: #ddd;
    }
</style>

@code {
    private User? currentUser;
    private bool isAuthorized;
    private string activeTab = "strategy";

    protected override void OnInitialized()
    {
        currentUser = authService.GetCurrentUser();
        isAuthorized = currentUser?.IsAdmin ?? false;

        if (!isAuthorized)
        {
            navigationManager.NavigateTo("/login");
        }
    }

    private void SelectTabStrategy()
    {
        activeTab = "strategy";
    }

    private void SelectTabRules()
    {
        activeTab = "rules";
    }

    private void SelectTabVotes()
    {
        activeTab = "votes";
    }

    private void CastVote(int voteId, bool votedFor)
    {
        // Логіка голосування
    }
}
