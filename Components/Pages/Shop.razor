@page "/shop"
@using Raven_Family.Services
@using Raven_Family.Models
@inject AuthService authService
@inject ShopService shopService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<PageTitle>🏪 Магазин - Сім'я Воронів</PageTitle>

@if (!authService.IsLoggedIn())
{
    <div class="alert alert-warning">
        <p>Будь ласка, <a href="/login">увійдіть</a> щоб отримати доступ до магазину.</p>
    </div>
}
else
{
    <div class="shop-container">
        <div class="shop-header">
            <h1>🛍️ Магазин Сім'ї Воронів</h1>
            <div class="wallet">
                <span>💰 Монети: <strong>@userBalance</strong></span>
            </div>
        </div>

        <div class="shop-tabs">
            <button class="tab @(activeCategory == "role" ? "active" : "")" @onclick='() => SetCategory("role")'>
                🎭 Ролі
            </button>
            <button class="tab @(activeCategory == "badge" ? "active" : "")" @onclick='() => SetCategory("badge")'>
                🏅 Бейджи
            </button>
            <button class="tab @(activeCategory == "cosmetic" ? "active" : "")" @onclick='() => SetCategory("cosmetic")'>
                ✨ Косметика
            </button>
        </div>

        <div class="items-grid">
            @foreach (var item in GetFilteredItems())
            {
                <div class="item-card">
                    <div class="item-icon">🎁</div>
                    <h3>@item.Name</h3>
                    <p class="item-desc">@item.Description</p>
                    <div class="item-price">
                        <span>💰 @item.Price</span>
                    </div>
                    <button class="btn-buy" 
                            @onclick="() => BuyItem(item.Id)" 
                            disabled="@(userBalance < item.Price)">
                        @(userBalance >= item.Price ? "Купити" : "Недостатньо коїнів")
                    </button>
                </div>
            }
        </div>

        @if (GetFilteredItems().Count == 0)
        {
            <div class="no-items">
                <p>У цій категорії поки немає товарів 👀</p>
            </div>
        }
    </div>
}

@code {
    private string activeCategory = "role";
    private long userBalance = 100;
    private List<ShopItem> allItems = new();

    protected override async Task OnInitializedAsync()
    {
        // Завантажити товари та баланс користувача
        // Це буде розроблено коли додамо сервіси
    }

    private void SetCategory(string category)
    {
        activeCategory = category;
    }

    private List<ShopItem> GetFilteredItems()
    {
        return allItems.Where(item => item.Category == activeCategory).ToList();
    }

    private async Task BuyItem(int itemId)
    {
        // Логіка покупки буде розроблена
        await Task.Delay(100);
    }
}

<style>
.shop-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}

.shop-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    background: linear-gradient(135deg, #1a0033 0%, #2d1b69 100%);
    padding: 30px;
    border-radius: 15px;
    color: white;
}

.shop-header h1 {
    margin: 0;
    font-size: 2.5em;
}

.wallet {
    background: rgba(0, 0, 0, 0.3);
    padding: 15px 25px;
    border-radius: 10px;
    font-size: 1.2em;
}

.shop-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    flex-wrap: wrap;
}

.tab {
    background: #1a0033;
    border: 2px solid #3d2d5e;
    color: #b899d6;
    padding: 12px 25px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    font-weight: bold;
    font-size: 1em;
}

.tab:hover,
.tab.active {
    background: #9d4edd;
    color: white;
    border-color: #9d4edd;
}

.items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
}

.item-card {
    background: linear-gradient(135deg, #1a0033 0%, #2d1b69 100%);
    border: 2px solid #3d2d5e;
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    color: white;
    transition: all 0.3s;
}

.item-card:hover {
    border-color: #9d4edd;
    box-shadow: 0 0 20px rgba(157, 78, 221, 0.3);
    transform: translateY(-5px);
}

.item-icon {
    font-size: 3em;
    margin-bottom: 15px;
}

.item-card h3 {
    margin: 0 0 10px 0;
    font-size: 1.3em;
    color: #d0a8ff;
}

.item-desc {
    color: #b899d6;
    font-size: 0.9em;
    margin: 0 0 15px 0;
}

.item-price {
    font-size: 1.5em;
    font-weight: bold;
    color: #ffd60a;
    margin-bottom: 15px;
}

.btn-buy {
    background: #9d4edd;
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    width: 100%;
    transition: all 0.3s;
}

.btn-buy:hover:not(:disabled) {
    background: #bb86fc;
    transform: scale(1.05);
}

.btn-buy:disabled {
    background: #555;
    cursor: not-allowed;
    opacity: 0.6;
}

.no-items {
    text-align: center;
    padding: 60px 20px;
    color: #b899d6;
    font-size: 1.2em;
}

.alert {
    background: #3d2d5e;
    border: 1px solid #9d4edd;
    color: #d0a8ff;
    padding: 15px 20px;
    border-radius: 8px;
    margin-bottom: 20px;
}

.alert a {
    color: #ffd60a;
    text-decoration: none;
    font-weight: bold;
}

.alert a:hover {
    text-decoration: underline;
}

@@media (max-width: 768px) {
    .shop-header {
        flex-direction: column;
        gap: 20px;
    }

    .items-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }

    .shop-header h1 {
        font-size: 1.8em;
    }
}
</style>
